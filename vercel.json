{
  "buildCommand": "pnpm --filter web build --configuration production",
  "outputDirectory": "apps/web/dist/web/browser",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "https://spectyra.up.railway.app/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
