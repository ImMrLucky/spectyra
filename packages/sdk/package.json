{
  "name": "@spectyra/sdk",
  "version": "0.1.3",
  "description": "Spectyra SDK for real-time LLM optimization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test:sdk-moat-summaries": "tsx src/__tests__/sdkMoatSummaries.test.ts",
    "test:optimization-engine-parity": "tsx src/__tests__/optimizationEngineParity.test.ts"
  },
  "keywords": [
    "llm",
    "optimization",
    "token-reduction",
    "spectyra",
    "claude",
    "agent",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spectyra/spectyra.git",
    "directory": "packages/sdk"
  },
  "dependencies": {
    "@spectyra/learning": "workspace:*",
    "@spectyra/execution-graph": "workspace:*",
    "@spectyra/state-delta": "workspace:*",
    "@spectyra/event-adapters": "workspace:*",
    "@spectyra/event-core": "workspace:*",
    "@spectyra/analytics-core": "workspace:*",
    "@spectyra/core-types": "workspace:*",
    "@spectyra/canonical-model": "workspace:*",
    "@spectyra/feature-detection": "workspace:*",
    "@spectyra/optimization-engine": "workspace:*",
    "@spectyra/shared": "workspace:*",
    "@spectyra/workflow-policy": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.1",
    "typescript": "~5.4.0"
  }
}
