{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [],
    "paths": {
      "@spectyra/shared": ["../../packages/shared/src/index.ts"],
      "@spectyra/shared/*": ["../../packages/shared/src/*"],
      "@spectyra/integration-metadata": ["../../packages/integration-metadata/src/index.ts"],
      "@spectyra/integration-metadata/*": ["../../packages/integration-metadata/src/*"],
      "@spectyra/analytics-core": ["../../packages/analytics-core/src/index.ts"],
      "@spectyra/analytics-core/*": ["../../packages/analytics-core/src/*"],
      "@spectyra/event-core": ["../../packages/event-core/src/index.ts"],
      "@spectyra/event-core/*": ["../../packages/event-core/src/*"],
      "@spectyra/openclaw-bridge": ["../../packages/openclaw-bridge/src/index.ts"],
      "@spectyra/openclaw-bridge/*": ["../../packages/openclaw-bridge/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
