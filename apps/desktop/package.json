{
  "name": "@spectyra/desktop",
  "version": "1.0.0",
  "description": "Spectyra Desktop App — local-first LLM optimization with built-in companion server",
  "main": "dist/main.js",
  "config": {
    "forge": "./forge.config.cjs"
  },
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "package": "tsc && electron-forge package",
    "make": "tsc && electron-forge make",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@spectyra/core-types": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-dmg": "^7.0.0",
    "@electron-forge/maker-squirrel": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "typescript": "~5.4.0"
  },
  "license": "MIT"
}
