{
  "name": "@spectyra/desktop",
  "version": "1.0.0",
  "description": "Spectyra Desktop — Electron shell + Local Companion (child process)",
  "main": "dist-electron/main.js",
  "author": "Spectyra",
  "license": "MIT",
  "scripts": {
    "compile:electron": "tsc -p tsconfig.electron.json",
    "prepare:companion": "node scripts/prepare-companion.cjs",
    "build:renderer": "pnpm --dir ../web exec ng build --configuration desktop",
    "build": "pnpm run compile:electron && pnpm run prepare:companion && pnpm run build:renderer",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder --publish never",
    "dev": "pnpm run compile:electron && cross-env SPECTYRA_ELECTRON_DEV_URL=http://127.0.0.1:4200 electron .",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@spectyra/core-types": "workspace:*",
    "@spectyra/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "cross-env": "^7.0.3",
    "electron": "28.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "~5.4.0"
  }
}
