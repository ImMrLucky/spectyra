{
  "name": "spectyra",
  "version": "0.1.0",
  "private": true,
  "description": "Spectral Token & Cost Reduction Engine",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "openclaw:build": "pnpm --filter @spectyra/desktop run build",
    "openclaw:dist": "pnpm --filter @spectyra/desktop run dist",
    "openclaw:dist:win": "pnpm --filter @spectyra/desktop run dist:win",
    "openclaw:dev": "pnpm --filter @spectyra/desktop run dev",
    "desktop-pro:build": "pnpm --filter @spectyra/desktop-pro run build",
    "desktop-pro:dist": "pnpm --filter @spectyra/desktop-pro run dist",
    "desktop-pro:dist:win": "pnpm --filter @spectyra/desktop-pro run dist:win",
    "desktop-pro:dev": "pnpm --filter @spectyra/desktop-pro run dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --recursive build",
    "typecheck": "pnpm --recursive typecheck",
    "test:event-spine": "pnpm --filter @spectyra/event-core run test:local-persistence",
    "test:event-ingestion": "pnpm --filter @spectyra/event-adapters run test:ingestion-pipeline",
    "test:analytics-session": "pnpm --filter @spectyra/analytics-core run test:session-tracker-smoke",
    "test:preserve-context": "pnpm --filter @spectyra/optimizer-algorithms run test:preserve-context-compiler",
    "test:moat-phase1-2": "pnpm test:preserve-core && pnpm test:preserve-context && pnpm test:anti-coupling && pnpm check:event-coupling && pnpm test:event-spine && pnpm test:event-ingestion && pnpm test:analytics-session",
    "test:execution-graph": "pnpm --filter @spectyra/execution-graph run test:execution-graph",
    "test:state-delta": "pnpm --filter @spectyra/state-delta run test:state-delta",
    "test:moat-through-3": "pnpm test:moat-phase1-2 && pnpm test:execution-graph",
    "test:moat-through-4": "pnpm test:moat-through-3 && pnpm test:state-delta && pnpm test:sdk-moat-summaries && pnpm test:sdk-optimization-parity",
    "test:learning-loop": "pnpm --filter @spectyra/learning run test:learning-loop && pnpm --filter @spectyra/optimization-engine run test:learning-gate",
    "test:moat-through-5": "pnpm test:moat-through-4 && pnpm test:learning-loop",
    "test:workflow-policy": "pnpm --filter @spectyra/workflow-policy run test:workflow-policy",
    "test:openclaw-bridge": "pnpm --filter @spectyra/openclaw-bridge run test",
    "build:local-companion": "pnpm --filter @spectyra/local-companion run build",
    "test:local-companion-inference": "pnpm --filter @spectyra/local-companion run test",
    "test:moat-through-6": "pnpm test:moat-through-5 && pnpm test:workflow-policy",
    "test:sdk-moat-summaries": "pnpm --filter @spectyra/sdk run test:sdk-moat-summaries",
    "test:sdk-optimization-parity": "pnpm --filter @spectyra/sdk run test:optimization-engine-parity",
    "test:preserve-core": "pnpm --filter @spectyra/optimizer-algorithms run test:preserve-smoke",
    "test:anti-coupling": "pnpm --filter @spectyra/optimization-engine run test:anti-coupling",
    "check:event-coupling": "node tools/check-event-coupling.mjs",
    "types:report": "tsx tools/type-report.ts",
    "types:report:strict": "tsx tools/type-report.ts --fail-on-collision"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.7.0",
    "typescript": "~5.4.0"
  },
  "packageManager": "pnpm@9.12.3"
}
