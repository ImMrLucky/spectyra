{
  "name": "@spectyra/local-companion",
  "version": "1.0.0",
  "type": "module",
  "description": "Spectyra Local Companion — local-first LLM optimization runtime for OpenClaw and other tools",
  "keywords": [
    "spectyra",
    "openai",
    "openai-compatible",
    "openclaw",
    "llm",
    "local",
    "proxy",
    "anthropic",
    "optimization"
  ],
  "main": "dist/companion.cjs",
  "bin": {
    "spectyra-companion": "./dist/cli.cjs"
  },
  "files": [
    "dist/cli.cjs",
    "dist/companion.cjs",
    "scripts/postinstall.cjs",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/companion.ts",
    "start": "tsx src/companion.ts",
    "benchmark": "node scripts/benchmark-savings.mjs",
    "postinstall": "node scripts/postinstall.cjs 2>/dev/null || true",
    "build": "node scripts/bundle.mjs",
    "build:tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/__tests__/inference-pipeline.test.ts && tsx src/__tests__/openclawAuthFallback.test.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@spectyra/event-adapters": "workspace:*",
    "@spectyra/learning": "workspace:*",
    "@spectyra/event-core": "workspace:*",
    "@spectyra/execution-graph": "workspace:*",
    "@spectyra/state-delta": "workspace:*",
    "@spectyra/workflow-policy": "workspace:*",
    "@spectyra/analytics-core": "workspace:*",
    "@spectyra/shared": "workspace:*",
    "@spectyra/core-types": "workspace:*",
    "@spectyra/canonical-model": "workspace:*",
    "@spectyra/feature-detection": "workspace:*",
    "@spectyra/optimization-engine": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.1",
    "typescript": "~5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/spectyra/spectyra.git",
    "directory": "tools/local-companion"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
